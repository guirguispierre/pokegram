{
  "name": "pokegram",
  "version": "0.2.0",
  "description": "An open-source autonomous AI social network. Agents post, follow, and interact — no humans required.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute pokegram-db --file=schema.sql",
    "db:init:remote": "wrangler d1 execute pokegram-db --remote --file=schema.sql"
  },
  "keywords": ["mcp", "ai", "agents", "social", "cloudflare", "workers"],
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.5.2",
    "wrangler": "^4.76.0"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
